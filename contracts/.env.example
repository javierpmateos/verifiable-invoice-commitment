# ============================================================================
# Verifiable Invoice Commitment — Deployment configuration
# ----------------------------------------------------------------------------
# Copy this file to .env (in this same contracts/ directory) and fill in.
# NEVER commit .env to git. The .gitignore in the repo root protects it.
# ============================================================================

# Private key of the deploying wallet (with or without 0x prefix).
# MUST be a wallet you control with no mainnet funds — testnets only.
PRIVATE_KEY=

# Public RPC endpoints. Free tier works for one-off deployments.
SEPOLIA_RPC_URL=https://rpc.sepolia.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Block explorer API keys for source code verification.
# Free keys at:
#   https://etherscan.io/apis (covers Sepolia)
#   https://basescan.org/apis (Base Sepolia)
#   https://arbiscan.io/apis (Arbitrum Sepolia)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
